{
  "name": "windrose-md",
  "version": "1.5.0",
  "description": "Dungeon mapping plugin for Obsidian via Datacore",
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "check": "npm run typecheck && npm run lint",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:e2e": "vitest run",
    "test:release": "vitest run --config vitest.release.config.ts",
    "test": "npm run test:unit && npm run test:e2e",
    "release": "npx tsx scripts/release/index.ts",
    "release:dry": "npx tsx scripts/release/index.ts --dry-run",
    "release:compile": "npx tsx scripts/release/compile.ts",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@blacksmithgu/datacore": "^0.1.0",
    "@playwright/test": "^1.48.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "happy-dom": "^20.1.0",
    "obsidian": "^1.11.0",
    "obsidian-testing-framework": "^0.1.6",
    "obsidian-typings": "^4.50.0",
    "patch-package": "^8.0.1",
    "polygon-clipping": "^0.15.7",
    "preact": "^10.25.0",
    "ts-plugin-datacore": "file:./ts-plugin-datacore",
    "typescript": "^5.7.0",
    "vitest": "^2.1.4"
  },
  "keywords": [
    "obsidian",
    "datacore",
    "dungeon",
    "mapping",
    "ttrpg"
  ],
  "license": "MIT"
}
