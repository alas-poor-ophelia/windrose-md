{
  "name": "windrose-md",
  "version": "2.0.3",
  "description": "Interactive dungeon and world mapping plugin for Obsidian",
  "type": "module",
  "imports": {
    "#types": "./types/index.ts",
    "#types/*": "./types/*.ts"
  },
  "scripts": {
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "check": "npm run typecheck && npm run lint",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:unit:watch": "vitest --config vitest.unit.config.ts",
    "test:e2e": "vitest run",
    "test:e2e:visible": "WINDROSE_E2E_VISIBLE=1 vitest run",
    "test:release": "vitest run --config vitest.release.config.ts",
    "test": "npm run test:unit && npm run test:e2e",
    "release": "npx tsx scripts/release/index.ts",
    "release:dry": "npx tsx scripts/release/index.ts --dry-run",
    "build:css": "sass scss/main.scss styles.css --no-source-map --no-charset",
    "build": "npm run build:css && node esbuild.config.mjs",
    "build:prod": "npm run build:css && node esbuild.config.mjs production",
    "build:watch": "node esbuild.config.mjs --watch",
    "build:css:watch": "sass scss/main.scss styles.css --no-source-map --no-charset --watch",
    "deploy": "npm run build:css && node esbuild.config.mjs && node -e \"const fs=require('fs');const d='C:/Users/whipl/OneDrive/Documents/Absalom/.obsidian/plugins/windrose-map-designer';['main.js','styles.css','manifest.json'].forEach(f=>fs.copyFileSync(f,d+'/'+f));console.log('Deployed to vault')\"",
    "postinstall": "patch-package",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.1",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-plugin-obsidianmd": "0.4.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "happy-dom": "^20.8.9",
    "interactjs": "^1.10.27",
    "obsidian": "^1.11.0",
    "obsidian-testing-framework": "^0.1.6",
    "obsidian-typings": "^4.50.0",
    "patch-package": "^8.0.1",
    "polygon-clipping": "^0.15.7",
    "preact": "^10.28.2",
    "sass": "^1.100.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.4"
  },
  "keywords": [
    "obsidian",
    "dungeon",
    "mapping",
    "ttrpg"
  ],
  "license": "MIT",
  "dependencies": {
    "@tanstack/virtual-core": "^3.17.0",
    "fflate": "^0.8.3"
  },
  "//overrides": "Security pins for transitive dev/test tooling flagged by the Obsidian store dependency scan. None of these ship in main.js (esbuild externalizes obsidian/electron/codemirror; the mermaid subtree comes from obsidian-typings for type annotations only and is never imported at runtime). preact is the sole runtime-bundled package and is pinned separately in devDependencies.",
  "overrides": {
    "mermaid": "^11.16.0",
    "dompurify": "^3.4.11",
    "uuid": "^11.1.1",
    "lodash-es": "^4.18.0",
    "qs": "^6.15.2",
    "postcss": "^8.5.10",
    "rollup": "^4.59.0",
    "ws": "^8.21.0",
    "tmp": "^0.2.6",
    "yaml": "^2.8.3",
    "js-yaml": "^4.2.0",
    "flatted": "^3.4.2",
    "fast-uri": "^3.1.2"
  },
  "resolutions": {
    "mermaid": "^11.16.0",
    "dompurify": "^3.4.11",
    "uuid": "^11.1.1",
    "lodash-es": "^4.18.0",
    "qs": "^6.15.2",
    "postcss": "^8.5.10",
    "rollup": "^4.59.0",
    "ws": "^8.21.0",
    "tmp": "^0.2.6",
    "yaml": "^2.8.3",
    "js-yaml": "^4.2.0",
    "flatted": "^3.4.2",
    "fast-uri": "^3.1.2"
  }
}
