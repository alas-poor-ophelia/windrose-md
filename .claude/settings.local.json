{
  "permissions": {
    "allow": [
      "Bash(npm run test:unit *)",
      "Bash(npm run test:e2e *)",
      "Bash(npm run check *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git -C *)",
      "Bash(npx vitest *)",
      "Skill(review-comments)",
      "Skill(review-src)",
      "Skill(release)",
      "mcp__ide__getDiagnostics",
      "Bash(dir:*)",
      "Bash(npm run test:unit:*)",
      "Bash(npm run check:*)",
      "Bash(git status:*)",
      "Bash(findstr:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$CLAUDE_TOOL_INPUT_FILE_PATH\" | grep -q 'tests/e2e' && npm run test:e2e || true"
          }
        ]
      }
    ]
  }
}
